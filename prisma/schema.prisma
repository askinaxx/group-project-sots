generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Domain {
  id            Int             @id @default(autoincrement())
  domainName    String          @unique @db.VarChar(255)
  registrar     String?         @db.VarChar(255)
  createdAt     DateTime?
  updatedAt     DateTime?
  expiresAt     DateTime?
  status        String?         @db.Text
  rdapUrl       String?         @db.VarChar(500)
  lastCheckedAt DateTime?
  nameservers   Nameserver[]
  lookups       LookupHistory[]
}

model Nameserver {
  id         Int    @id @default(autoincrement())
  domainId   Int
  nameserver String @db.VarChar(255)
  domain     Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)
}

model LookupHistory {
  id             Int      @id @default(autoincrement())
  domainId       Int?
  domainName     String   @db.VarChar(255)
  queryType      String   @db.VarChar(50)
  responseStatus Int?
  success        Boolean
  checkedAt      DateTime @default(now())
  rawResponse    String?  @db.LongText
  errorMessage   String?  @db.Text
  domain         Domain?  @relation(fields: [domainId], references: [id], onDelete: SetNull)
}